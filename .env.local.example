# ───────────────────────────────────────────────
# Vercel Postgres (Vercel dashboard > Storage)
# Proje oluşturunca bu değerler otomatik env'lere eklenir.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ───────────────────────────────────────────────
# Vercel Blob (Vercel dashboard > Storage > Create Blob Store)
# Oluşturduktan sonra .env'e "Read/Write" token'ı kopyalayın
BLOB_READ_WRITE_TOKEN=

# ───────────────────────────────────────────────
# Admin girişi (tek admin / basit parola)
# Üretimde güçlü, uzun ve rastgele değerler kullanın
ADMIN_PASSWORD=changeme123
AUTH_SECRET=change-this-to-a-long-random-string-min-32-chars
